# Dependencies
node_modules/
.npm/

# Frontend build output
dist/
.vite/

# Tauri/Rust build output
src-tauri/target/
src-tauri/gen/

# Logs
*.log
logs/*.jsonl
logs/events/*.jsonl
logs/services/*.jsonl
logs/audit/*.jsonl
logs/crash-bundles/*.json
!logs/.gitkeep
!logs/events/.gitkeep
!logs/services/.gitkeep
!logs/audit/.gitkeep
!logs/crash-bundles/.gitkeep
system/recovery-snapshots/*.json
system/restore-points/*.json
system/backups/*.json
system/update-staging/*
!system/recovery-snapshots/.gitkeep
!system/restore-points/.gitkeep
!system/backups/.gitkeep
!system/update-staging/.gitkeep
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
vite-dev.log
vite-dev.err.log

# Environment and local config
.env
.env.*
!.env.example
*.local
*.local.*

# Editor and OS files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
.idea/
.DS_Store
Thumbs.db
desktop.ini

# Test and coverage output
coverage/
.nyc_output/
test-results/
playwright-report/
junit.xml
*.lcov

# Generated installers and bundles
*.msi
*.exe
*.dmg
*.AppImage
*.deb
*.rpm

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*.swo

# Local archives and release artifacts
artifacts/
*.zip
*.7z
*.tar.gz

# Keep release documentation and checksums, but do not commit binaries.
release/*
!release/.gitkeep
!release/README.md
!release/RELEASE_NOTES_v1.1.2.md
!release/SHA256SUMS.txt
