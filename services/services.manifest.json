{
  "schema": "aether.services.manifest.v1",
  "target": "graphical",
  "services": [
    { "id": "init", "name": "Aether Init", "daemon": "aether-initd", "boot": true, "enabled": true, "status": "running", "restart": "always", "health": "healthy", "requires": [], "permissions": ["kernel.boot", "services.manage", "services.enable", "boot.targets.apply"] },
    { "id": "registry", "name": "Kernel Registry Service", "daemon": "aether-regd", "boot": true, "enabled": true, "status": "running", "restart": "on-failure", "health": "healthy", "requires": ["init"], "permissions": ["kernel.registry.read", "kernel.registry.write"] },
    { "id": "drivers", "name": "Driver Manager", "daemon": "aether-devd", "boot": true, "enabled": true, "status": "running", "restart": "on-failure", "health": "healthy", "requires": ["registry"], "permissions": ["drivers.manage", "devices.scan"] },
    { "id": "pkgd", "name": "Package Registry Daemon", "daemon": "aether-pkgd", "boot": true, "enabled": true, "status": "running", "restart": "on-failure", "health": "healthy", "requires": ["registry"], "permissions": ["packages.manage"] },
    { "id": "recovery", "name": "Recovery Supervisor", "daemon": "aether-recoveryd", "boot": true, "enabled": true, "status": "running", "restart": "always", "health": "healthy", "requires": ["registry", "drivers", "pkgd"], "permissions": ["recovery.snapshot", "recovery.repair", "logs.write"] },
    { "id": "eventbus", "name": "System Event Bus", "daemon": "aether-eventd", "boot": true, "enabled": true, "status": "running", "restart": "always", "health": "healthy", "requires": ["registry"], "permissions": ["events.publish", "events.subscribe", "logs.write"] },
    { "id": "indexer", "name": "System Search Indexer", "daemon": "aether-indexd", "boot": true, "enabled": true, "status": "running", "restart": "on-failure", "health": "healthy", "requires": ["eventbus", "drivers"], "permissions": ["filesystem.read", "search.index", "events.publish"] },
    { "id": "taskd", "name": "Task Scheduler", "daemon": "aether-taskd", "boot": true, "enabled": true, "status": "running", "restart": "on-failure", "health": "healthy", "requires": ["eventbus", "registry"], "permissions": ["tasks.run", "tasks.manage"] },
    { "id": "crashd", "name": "Crash Reporter", "daemon": "aether-crashd", "boot": true, "enabled": true, "status": "running", "restart": "always", "health": "healthy", "requires": ["eventbus", "recovery"], "permissions": ["crash.bundle", "logs.read", "recovery.snapshot"] },
    { "id": "updated", "name": "Aether Update Engine", "daemon": "aether-updated", "boot": true, "enabled": true, "status": "running", "restart": "on-failure", "health": "healthy", "requires": ["eventbus", "pkgd", "recovery"], "permissions": ["updates.manage", "packages.manage", "recovery.snapshot"] },
    { "id": "netd", "name": "Network Manager", "daemon": "aether-netd", "boot": true, "enabled": true, "status": "running", "restart": "always", "health": "healthy", "requires": ["eventbus", "drivers"], "permissions": ["network.manage", "firewall.manage", "events.publish"] },
    { "id": "accountsd", "name": "Account Manager", "daemon": "aether-accountsd", "boot": true, "enabled": true, "status": "running", "restart": "always", "health": "healthy", "requires": ["eventbus", "registry"], "permissions": ["accounts.manage", "auth.elevate", "events.publish"] },
    { "id": "storaged", "name": "Storage Manager", "daemon": "aether-storaged", "boot": true, "enabled": true, "status": "running", "restart": "on-failure", "health": "healthy", "requires": ["eventbus", "drivers"], "permissions": ["storage.manage", "filesystem.read", "events.publish"] },
    { "id": "auditd", "name": "Audit Log Service", "daemon": "aether-auditd", "boot": true, "enabled": true, "status": "running", "restart": "always", "health": "healthy", "requires": ["eventbus"], "permissions": ["audit.write", "audit.export", "logs.write"] },
    { "id": "backupd", "name": "Backup Service", "daemon": "aether-backupd", "boot": true, "enabled": true, "status": "running", "restart": "on-failure", "health": "healthy", "requires": ["eventbus", "storaged", "recovery"], "permissions": ["backup.manage", "storage.manage", "recovery.snapshot"] },
    { "id": "policyd", "name": "Policy Engine", "daemon": "aether-policyd", "boot": true, "enabled": true, "status": "running", "restart": "always", "health": "healthy", "requires": ["eventbus", "accountsd", "auditd"], "permissions": ["policy.enforce", "audit.write", "events.publish"] },
    { "id": "shellexp", "name": "Shell Experience Manager", "daemon": "aether-experienced", "boot": true, "enabled": true, "status": "running", "restart": "always", "health": "healthy", "requires": ["eventbus", "registry", "ui"], "permissions": ["shell.manage", "settings.extend", "events.publish"] },
    { "id": "ecosystemd", "name": "Aether Ecosystem Service", "daemon": "aether-ecosystemd", "boot": true, "enabled": true, "status": "running", "restart": "on-failure", "health": "healthy", "requires": ["eventbus", "pkgd", "policyd"], "permissions": ["ecosystem.manage", "packages.manage", "shell.extend", "events.publish"] },
    { "id": "hardeningd", "name": "Security Hardening Service", "daemon": "aether-hardeningd", "boot": true, "enabled": true, "status": "running", "restart": "always", "health": "healthy", "requires": ["eventbus", "policyd", "auditd", "shield"], "permissions": ["hardening.evaluate", "policy.enforce", "audit.write", "events.publish"] },
    { "id": "shield", "name": "Aether Shield", "daemon": "aether-shieldd", "boot": true, "enabled": true, "status": "running", "restart": "always", "health": "healthy", "requires": ["drivers"], "permissions": ["filesystem.scan", "quarantine.write", "permissions.approve"] },
    { "id": "ui", "name": "Aether Shell UI", "daemon": "aether-shelld", "boot": true, "enabled": true, "status": "running", "restart": "on-failure", "health": "healthy", "requires": ["drivers", "pkgd"], "permissions": ["ui.launch", "notifications.send"] }
  ]
}
